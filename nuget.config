<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
		<!-- Locally built Xamarin.GooglePlayServices.Ads.Lite 124.0.0.8 from
		     dotnet/android-libraries#1356 (MediaContent binding fix, needed for
		     native video / issue #78). Remove this source and the .nuget/local
		     folder once the fix ships on nuget.org. -->
		<add key="local" value=".nuget/local" />
	</packageSources>
</configuration>
